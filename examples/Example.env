# Environment variables consumed by the translator.
#
# To use, copy this file to ".env" in the project root, or export the
# variables in your shell. Values set inline in the pipeline config file
# (`api_key`, `api_base`, `model`) take precedence over these.

# OpenAI-compatible providers
#   Works with: chatgpt, deepseek, openrouter, groq, ollama, any other
#   OpenAI-compatible HTTP endpoint.
#   The translator config picks `provider = "openai"` for any of these,
#   then routes by api_base + model.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_HTTP_PROXY=

# Google Gemini  (provider = "gemini")
#   API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-002
